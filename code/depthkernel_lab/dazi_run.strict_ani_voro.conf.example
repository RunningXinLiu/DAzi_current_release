# Legacy explicit --config example for anisotropic Vorotomo cases where the
# priority is strict equivalence to the original Fortran baseline. The server
# handoff package normally reads runtime controls from para.in.

profile = strict_ani_voro

threads = 4
omp_threads = 4
ti_workers = 4

# Explicit values are included to make the stable contract obvious.
# This preserves the original isotropic finite-difference sensitivity kernel,
# while using only exact-validated acceleration for TI and Vorotomo GP.
depthkernel_backend = default
depthkernel_ti_backend = process_batch
voro_gp_backend = direct

pdsurf_tile_columns = 64
ti_tile_columns = 64

python = /opt/miniconda3/envs/dispa/bin/python
binary = /Users/liuxin/Desktop/DSurf_test/DAzi_vorotomo_migration/bin/DAzimSurfTomo
ti_batch_script = /Users/liuxin/Desktop/DSurf_test/DAzi_vorotomo_migration/depthkernel_lab/depthkernel_ti_process_batch.py
ti_worker = /Users/liuxin/Desktop/DSurf_test/DAzi_vorotomo_migration/depthkernel_lab/depthkernel_ti_worker
infile = para.in

voro_timer = 0
omp_proc_bind = unset
omp_places = unset
